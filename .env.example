# ============================================================
# Apple MDM Academy — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local.
# Configurer ces variables dans Vercel > Project Settings > Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : UNIQUEMENT côté serveur (admin bypass RLS) — ne jamais exposer côté client
# SUPABASE_SERVICE_ROLE_KEY=

# ── URL publique ──────────────────────────────────────────────────────────────
# URL de production ou preview (utilisée pour emailRedirectTo et callbacks auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Session démo (optionnel) ──────────────────────────────────────────────────
# Si défini (≥ 16 caractères), signe le cookie ama_demo_session (HMAC)
# DEMO_SESSION_SECRET=

# ── Emails admin ──────────────────────────────────────────────────────────────
# Liste d'emails séparés par des virgules — accès à l'interface /admin
# Ajouter aussi ces emails dans la table admin_allowlist via le SQL Editor Supabase
ADMIN_EMAILS=admin@votre-entreprise.fr

# ── Contact form — Resend ─────────────────────────────────────────────────────
# Créer un compte sur https://resend.com et générer une API key
# Vérifier votre domaine dans Resend pour pouvoir envoyer depuis noreply@votre-domaine.fr
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email de destination des messages de contact (votre boîte admin)
CONTACT_EMAIL=contact@votre-entreprise.fr

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard : https://dashboard.stripe.com/apikeys
# En mode test : clés commençant par sk_test_
# En production : clés commençant par sk_live_
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Price IDs de vos plans (Dashboard Stripe > Products)
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optionnel : Stripe côté client (publique) ─────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optionnel : Assistant IA ──────────────────────────────────────────────────
# Anthropic API key pour l'assistant pédagogique /assistant
# Créer sur https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optionnel : Analytics ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Stripe Price IDs (mensuels) ───────────────────────────────────────────────
# Dashboard Stripe > Produits > Prix récurrents
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Service Role (optionnel) ─────────────────────────────────────────
# Uniquement nécessaire pour les actions admin côté serveur (bypass RLS).
# NE JAMAIS exposer côté client — réserver aux Server Components/API Routes.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Note : Variables Vercel automatiques ─────────────────────────────────────
# Ces variables sont injectées automatiquement par Vercel, ne pas les définir :
# VERCEL_URL, VERCEL_ENV, VERCEL_GIT_COMMIT_SHA, VERCEL_DEPLOYMENT_ID, NODE_ENV

# ── Webhook Supabase (optionnel) ──────────────────────────────────────────────
# Secret partagé pour valider les webhooks Supabase → emails automatiques
# Configurer dans Supabase > Database > Webhooks > Headers
# SUPABASE_WEBHOOK_SECRET=your-webhook-secret
